# .env.example — copy to .env and fill in values for LIVE mode only.
# Offline mode (EVAL_MODE=offline) requires NO secrets.
# NEVER commit .env — it is gitignored.

# Used by the SUT generator (gpt-4o-mini) and embeddings (live mode).
# Also used by the judge (gpt-4o) for faithfulness/relevance scoring.
OPENAI_API_KEY=

# Optional: out-of-family judge (DeepSeek) to reduce self-preference bias.
# See README §10 for details.
DEEPSEEK_API_KEY=

# Set to "offline" (default in CI) for deterministic fixture-based runs.
# Set to "live" to use real OpenAI calls.
EVAL_MODE=offline
